@model HuntingPermitTripManagement.Web.Models.PermitViewModel

@{
    ViewData["Title"] = "Edit Permit";
}

<h1 class="mb-4">Edit Permit</h1>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

<form asp-action="Edit" method="post" class="w-50">

    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="UserId" class="form-label">User Id</label>
        <input asp-for="UserId" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="PermitNumber" class="form-label">Permit Number</label>
        <input asp-for="PermitNumber" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="PermitType" class="form-label">Permit Type</label>
        <input asp-for="PermitType" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="IssueDate" class="form-label">Issue Date</label>
        <input asp-for="IssueDate" type="date" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="ExpirationDate" class="form-label">Expiration Date</label>
        <input asp-for="ExpirationDate" type="date" class="form-control" />
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label">Active Permit</label>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>

    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>