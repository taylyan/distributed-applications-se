@model HuntingPermitTripManagement.Web.Models.HarvestRecordViewModel

@{
    ViewData["Title"] = "Delete Harvest Record";
}

<h1 class="mb-4">Delete Harvest Record</h1>

<div class="alert alert-warning">
    Are you sure you want to delete this harvest record?
</div>

<table class="table table-bordered w-50">
    <tr>
        <th>Id</th>
        <td>@Model.Id</td>
    </tr>
    <tr>
        <th>Trip Id</th>
        <td>@Model.TripId</td>
    </tr>
    <tr>
        <th>Animal Type</th>
        <td>@Model.AnimalType</td>
    </tr>
    <tr>
        <th>Quantity</th>
        <td>@Model.Quantity</td>
    </tr>
    <tr>
        <th>Weight</th>
        <td>@Model.Weight kg</td>
    </tr>
    <tr>
        <th>Legal</th>
        <td>@Model.IsLegal</td>
    </tr>
    <tr>
        <th>Recorded At</th>
        <td>@Model.RecordedAt.ToString("yyyy-MM-dd")</td>
    </tr>
</table>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" name="id" value="@Model.Id" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>
</form>